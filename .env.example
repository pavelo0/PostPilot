# PostgreSQL (локально через docker-compose)
DATABASE_URL="postgresql://postpilot:postpilot@localhost:5432/postpilot"

# API
PORT=3000
NODE_ENV=development

# Telegram per-user token encryption key (base64 for 32-byte key)
# BOT_TOKEN_ENCRYPTION_KEY=

# Mock subscription plan (basic | pro | enterprise)
# DEFAULT_SUBSCRIPTION_PLAN=basic

# Frontend ходит в API через Vite proxy: /api → localhost:3000

# Sentry (optional — leave empty for local dev)
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=development
