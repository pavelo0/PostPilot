NODE_ENV=production
PORT=3000

# Same-origin via Caddy — CORS usually not needed in production
# CORS_ORIGIN=https://app.example.com

# Docker network hostname for Postgres service
DATABASE_URL="postgresql://postpilot:postpilot@postgres:5432/postpilot"

SESSION_COOKIE_NAME=postpilot_session
SESSION_TTL_DAYS=14
EMAIL_VERIFICATION_TTL_MINUTES=10
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_SENDS_PER_WINDOW=5
EMAIL_VERIFICATION_RATE_WINDOW_MINUTES=60
EXPOSE_EMAIL_VERIFICATION_CODE=false
LOG_EMAIL_VERIFICATION_CODE=false

# Resend — https://resend.com (see docs/email-delivery.md)
RESEND_API_KEY=
EMAIL_FROM=PostPilot <onboarding@resend.dev>
# EMAIL_VERIFICATION_SUBJECT=PostPilot — код подтверждения

# Required in production — generate: openssl rand -base64 32
BOT_TOKEN_ENCRYPTION_KEY=

DEFAULT_SUBSCRIPTION_PLAN=basic
