NODE_ENV=production
PORT=3000

DATABASE_URL="postgresql://postpilot:postpilot@localhost:5433/postpilot"

# Local: redis://localhost:6379 | Prod (Upstash): rediss://...
REDIS_URL="redis://localhost:6379"

MEDIA_STORAGE=local
MEDIA_STORAGE_PATH=./data/media
# Prod (R2):
# MEDIA_STORAGE=s3
# S3_BUCKET=post-pilot-media
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto

SESSION_COOKIE_NAME=postpilot_session
SESSION_TTL_DAYS=14
EMAIL_VERIFICATION_TTL_MINUTES=10
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_SENDS_PER_WINDOW=5
EMAIL_VERIFICATION_RATE_WINDOW_MINUTES=60
EXPOSE_EMAIL_VERIFICATION_CODE=false
LOG_EMAIL_VERIFICATION_CODE=false

RESEND_API_KEY=
EMAIL_FROM=PostPilot <onboarding@resend.dev>
APP_PUBLIC_URL=https://post-pilot-sigma-sepia.vercel.app

BOT_TOKEN_ENCRYPTION_KEY=
DEFAULT_SUBSCRIPTION_PLAN=basic