# Production / staging environment for docker-compose.prod.yml
# Copy to .env in repo root and fill in secrets before deploy.

# Public site address for Caddy.
# Local HTTP test:  CADDY_SITE=http://localhost
# Production HTTPS: CADDY_SITE=app.example.com
CADDY_SITE=http://localhost

# Legacy alias — use CADDY_SITE instead
DOMAIN=localhost

# Optional: Let's Encrypt contact email (required for real domains)
# CADDY_EMAIL=you@example.com

# Postgres
POSTGRES_USER=postpilot
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=postpilot

# API — required in production (generate: openssl rand -base64 32)
BOT_TOKEN_ENCRYPTION_KEY=

# Session
SESSION_COOKIE_NAME=postpilot_session
SESSION_TTL_DAYS=14

# Email verification (keep false on staging/prod)
EXPOSE_EMAIL_VERIFICATION_CODE=false
LOG_EMAIL_VERIFICATION_CODE=false

DEFAULT_SUBSCRIPTION_PLAN=basic
